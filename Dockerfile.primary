# =============================================================================
# Disclaude Primary Node Dockerfile
# =============================================================================
# Multi-stage build for Primary Node - handles Feishu WebSocket + Agent execution.
#
# Build:
#   docker build -f Dockerfile.primary -t disclaude:primary .
#
# Run:
#   docker run -v $(pwd)/disclaude.config.yaml:/app/disclaude.config.yaml -v $(pwd)/workspace:/data/workspace -v $(pwd)/logs:/data/logs disclaude:primary
#
# For production deployment, use docker-compose.yml.
# =============================================================================

# -----------------------------------------------------------------------------
# Build arguments for configurable source mirrors (Issue #2283)
# Defaults use official sources; override via docker-source.env for mirrors.
# Note: APT_MIRROR replaces the former APK_MIRROR after migrating to Debian-slim (#4115).
# -----------------------------------------------------------------------------
ARG DOCKER_IMAGE_PREFIX=
ARG APT_MIRROR=
ARG NPM_REGISTRY=https://registry.npmjs.org
ARG PIP_INDEX_URL

# -----------------------------------------------------------------------------
# Stage 1: Builder (uses bun for faster installs)
# -----------------------------------------------------------------------------
FROM ${DOCKER_IMAGE_PREFIX}library/node:22-slim AS builder

# Re-declare build args for use in this stage
ARG APT_MIRROR
ARG NPM_REGISTRY

WORKDIR /app

# Configure apt mirror if provided (default: official Debian repos)
RUN if [ -n "${APT_MIRROR}" ]; then \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi && \
    apt-get update

# Install build dependencies + bun (via npm, since Node.js is already present in this stage)
RUN apt-get install -y --no-install-recommends python3 make g++ && \
    rm -rf /var/lib/apt/lists/* && \
    npm config set registry ${NPM_REGISTRY} && \
    npm install -g bun

# Copy package files
# tsconfig.json is required by `tsc -b` (root project references) in the build step below.
COPY package.json package-lock.json tsconfig.json ./
COPY packages ./packages

# Install dependencies using bun
# Bun reads package-lock.json and generates bun.lock on the fly (single source of truth).
# BUN_CONFIG_REGISTRY controls which registry bun resolves from (Issue #2283).
ENV BUN_CONFIG_REGISTRY=${NPM_REGISTRY}
RUN bun install

# Build the project
# Root "build" script uses "tsc -b" which follows project references to build all packages
# (core → mcp-server → primary-node). Using local tsc binary avoids npx overhead.
RUN ./node_modules/.bin/tsc -b

# Copy source code (explicitly list needed dirs to avoid traversing excluded directories like workspace)
# Note: placed after build step to improve Docker layer caching - skills changes won't invalidate the build cache
COPY skills ./skills

# Prune devDependencies for production
# Note: cache cleanup reduces builder layer size (no impact on final multi-stage image)
RUN bun install --production && \
    rm -rf /root/.bun/install/cache

# -----------------------------------------------------------------------------
# Stage 2: Production Image
# -----------------------------------------------------------------------------
FROM ${DOCKER_IMAGE_PREFIX}library/node:22-slim AS production

# Re-declare build args for use in this stage
ARG APT_MIRROR
ARG NPM_REGISTRY
ARG PIP_INDEX_URL

WORKDIR /app

# Configure apt mirror if provided (default: official Debian repos)
RUN if [ -n "${APT_MIRROR}" ]; then \
      sed -i "s|deb.debian.org|${APT_MIRROR}|g" /etc/apt/sources.list.d/debian.sources; \
    fi && \
    apt-get update

# Install runtime + build dependencies, GitHub CLI, and gosu
# Consolidated into a single RUN to minimize apt-get update calls (Issue #4115 review).
# gosu replaces su-exec (Alpine) for privilege dropping on Debian (Issue #4114).
RUN apt-get install -y --no-install-recommends \
        curl \
        ca-certificates \
        procps \
        bash \
        python3 \
        python3-pip \
        tini \
        sudo \
        gosu \
        g++ gcc make cmake python3-dev && \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
        | dd of=/usr/share/keyrings/githubcli-archive-keyring.gpg && \
    chmod go+r /usr/share/keyrings/githubcli-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
        > /etc/apt/sources.list.d/github-cli.list && \
    apt-get update && \
    apt-get install -y --no-install-recommends gh && \
    rm -rf /var/lib/apt/lists/*

# Install common Python data analysis packages
# PIP_INDEX_URL: override PyPI mirror (default: official https://pypi.org/simple)
RUN pip3 install --no-cache-dir --break-system-packages ${PIP_INDEX_URL:+--index-url $PIP_INDEX_URL} matplotlib numpy

# Install @larksuite/cli globally
# Issue #3888: @larksuite/cli needed by dissolve-group, lark-docs, pr-scanner skills
RUN npm config set registry ${NPM_REGISTRY} && \
    npm install -g "@larksuite/cli@>=1.0.0"

# Create non-root user for running the application
RUN groupadd -g 1001 disclaude && \
    useradd -u 1001 -g disclaude -d /app -s /usr/sbin/nologin -m disclaude

# Grant the non-root user passwordless sudo for apt-get only, so the agent can
# install system packages on demand (e.g. `sudo apt-get install -y llvm-dev`)
# without running the whole process as root. Restricted to apt-get to prevent
# accidental destructive operations. Staying uid 1001 preserves
# /data/workspace ownership so the host can still read/write the mounted
# volume. visudo validates the file at build time (fails on syntax error).
RUN echo "Defaults:disclaude logfile=/data/logs/sudo.log" > /etc/sudoers.d/disclaude-audit && \
    echo "disclaude ALL=(ALL) NOPASSWD: /usr/bin/apt-get" > /etc/sudoers.d/disclaude && \
    chmod 0440 /etc/sudoers.d/disclaude-audit /etc/sudoers.d/disclaude && \
    visudo -cf /etc/sudoers.d/disclaude-audit && visudo -cf /etc/sudoers.d/disclaude

# Create directories for runtime with proper permissions
RUN mkdir -p /data/workspace /data/logs /app/.claude /app/.claude/backups /app/.claude/debug && \
    echo '{}' > /app/.claude.json && \
    chown -R disclaude:disclaude /app /data

# Copy built artifacts and production dependencies from builder
COPY --from=builder --chown=disclaude:disclaude /app/packages ./packages
COPY --from=builder --chown=disclaude:disclaude /app/node_modules ./node_modules
COPY --from=builder --chown=disclaude:disclaude /app/package.json ./
COPY --from=builder --chown=disclaude:disclaude /app/package-lock.json ./
COPY --from=builder --chown=disclaude:disclaude /app/skills ./skills

# Copy entrypoint script (Issue #3987: auto-configure lark-cli auth)
# Issue #4114: also sets oom_score_adj to protect primary process
COPY --chown=disclaude:disclaude docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
RUN chmod +x /usr/local/bin/docker-entrypoint.sh

# Use entrypoint script that runs as root for OOM protection + lark-cli auth,
# then drops to non-root user via gosu before starting tini + application.
# Issue #3987: auto-configure lark-cli auth from disclaude.config.yaml
# Issue #4114: set oom_score_adj to protect primary process from OOM killer
ENTRYPOINT ["docker-entrypoint.sh"]

# Set environment variables
ENV NODE_ENV=production
ENV DISCLAUDE_MODE=primary

# Issue #4114: Cap agent-spawned compile parallelism to prevent OOM from massive cc1plus forks.
# MAKEFLAGS limits make-based builds; CMAKE_BUILD_PARALLEL_LEVEL limits CMake builds.
# Override at runtime via docker-compose environment section if needed.
ENV MAKEFLAGS="-j2"
ENV CMAKE_BUILD_PARALLEL_LEVEL=2

# Health check - verify Node.js process is running
# Uses pgrep with exact binary path to avoid false positives
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD pgrep -f "packages/primary-node/dist/cli.js" > /dev/null 2>&1 || exit 1

# Note: no USER directive — the entrypoint runs as root for oom_score_adj setup,
# then drops to the non-root user (disclaude) via gosu before exec'ing CMD.

# Default command: run Primary Node directly
CMD ["node", "packages/primary-node/dist/cli.js", "start"]
