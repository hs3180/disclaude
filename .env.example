# =============================================================================
# Disclaude Docker Environment Variables
# =============================================================================
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   docker compose up -d
#
# =============================================================================

# GitHub Personal Access Token for git operations
# Create at: https://github.com/settings/tokens
# Required scopes (select based on your needs):
#   - repo: Full control of private repositories (for clone, push, PR creation)
#   - workflow: Update GitHub Action workflows (if needed)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Workspace host path for the /data/workspace bind mount.
# Default: ./workspace (relative to the compose file). Set this to relocate the
# workspace, e.g. to a larger/SSD volume:
#   WORKSPACE_DIR=/ssd/disclaude/workspace
# IMPORTANT: the container runs as uid 1001 (disclaude), so this host directory
# MUST be owned by 1001:1001. If it does not exist yet, docker creates it as
# root:root and message handling fails with EACCES — create + chown it first:
#   sudo mkdir -p $WORKSPACE_DIR && sudo chown 1001:1001 $WORKSPACE_DIR
# WORKSPACE_DIR=./workspace

# Debian apt mirror
# Default: (empty = official deb.debian.org)
# China mirrors: mirrors.ustc.edu.cn, mirrors.aliyun.com, mirrors.tuna.tsinghua.edu.cn
# APT_MIRROR=mirrors.ustc.edu.cn

# npm registry
# Default: https://registry.npmjs.org
# China mirrors: https://registry.npmmirror.com
# NPM_REGISTRY=https://registry.npmmirror.com

# pip index URL
# Default: https://pypi.org/simple
# China mirrors: https://mirrors.ustc.edu.cn/pypi/web/simple, https://pypi.tuna.tsinghua.edu.cn/simple, https://mirrors.aliyun.com/pypi/simple
# PIP_INDEX_URL=https://mirrors.ustc.edu.cn/pypi/web/simple

# Docker base image prefix
# Default: (empty = docker.io)
# China mirrors: docker.m.daocloud.io
# DOCKER_IMAGE_PREFIX=docker.m.daocloud.io/

# GitHub CLI install mode
# Default: apt-repo (official GitHub apt source, may be slow from mainland China)
# Set to "deb" with GH_DEB_URL to download a .deb directly from a mirror.
# Valid values: apt-repo | deb  (any other value fails the build)
# GH_INSTALL_MODE=deb
# GH_DEB_URL=https://github.com/cli/cli/releases/download/v2.63.2/gh_2.63.2_linux_amd64.deb
# NOTE: GH_DEB_URL above is amd64 only; on arm64 hosts use gh_<ver>_linux_arm64.deb
#       (the apt-repo mode auto-detects architecture via dpkg --print-architecture).

# =============================================================================
# OOM Protection (Issue #4114)
# =============================================================================
# Protect the primary node from OOM killer when agent subprocesses consume
# excessive memory (e.g., pip source builds, compiler jobs).

# oom_score_adj for the primary process, applied host-side by Docker via the
# `oom_score_adj` field in docker-compose.yml. cgroup v2 forbids setting a
# negative value from inside the container, so this can NOT be done in the
# entrypoint — it must be set here.
# Range: -1000 (never kill) to +1000 (always kill first)
# Default: -500 (strong preference to keep alive)
# OOM_SCORE_ADJ=-500

# Compile parallelism caps (limits concurrent cc1plus / pip build processes)
# Default: -j2 (2 parallel jobs) — safe for containers with 8-16 GB RAM
# Increase for larger containers: MAKEFLAGS=-j4
# MAKEFLAGS=-j2
# CMAKE_BUILD_PARALLEL_LEVEL=2

# =============================================================================
# Playwright Container (optional)
# =============================================================================
# Start with: docker compose --profile playwright up -d
#
# Uses Docker bridge network. The CDP endpoint is only available internally at:
#   http://disclaude-playwright:{CDP_PORT}
#
# NOTE: Chrome (148+, --headless=new) ignores --remote-debugging-address (binds CDP
# to 127.0.0.1 only) AND rejects a non-IP Host header (HTTP 500). The container runs
# an nginx reverse proxy on {CDP_PORT} that forwards to Chrome's loopback listener on
# {CDP_INTERNAL_PORT} while rewriting Host -> localhost, so the MCP client can connect
# via the container hostname with no extra flags.
#
# Configure in disclaude.config.yaml:
#   tools:
#     mcpServers:
#       playwright:
#         command: npx
#         args: ["-y", "@playwright/mcp@latest",
#                "--cdp-endpoint", "http://disclaude-playwright:9222"]
# =============================================================================

# Playwright Docker image tag
# Default: v1.52.2-noble
# See available tags: https://mcr.microsoft.com/v2/playwright/tags/list
# PLAYWRIGHT_IMAGE_TAG=v1.52.2-noble

# CDP (Chrome DevTools Protocol) port — external port other containers connect to
# (nginx listens here). Default: 9222
# CDP_PORT=9222

# Chrome's internal loopback-only CDP port (nginx forwards CDP_PORT -> this).
# MUST differ from CDP_PORT (otherwise nginx cannot bind). Default: 9221
# CDP_INTERNAL_PORT=9221

# =============================================================================
# Filebeat Log Forwarder (optional)
# =============================================================================
# Start with: docker compose --profile logging up -d
# Configure ES connection below — works with any Elasticsearch instance
# (Docker container, remote server, cloud-managed, etc.)
# =============================================================================

# Filebeat image version
# FILEBEAT_VERSION=8.18.0

# Enable file logging (required for Filebeat to read logs)
# Must be set when using: docker compose --profile logging up -d
# LOG_TO_FILE=true

# Elasticsearch connection
# ES_HOST=localhost
# ES_PORT=9200
# ES auth — enabled by default. Set your ES credentials here.
# For unsecured ES, comment out ES_USERNAME/ES_PASSWORD here AND the
# matching ELASTICSEARCH_USERNAME/PASSWORD lines in docker-compose.yml
# (and username/password in filebeat.yml) to avoid HTTP 401 from empty values.
ES_USERNAME=elastic
ES_PASSWORD=

# =============================================================================
# Disclaude Runtime Flags
# =============================================================================
# Behavior flags for the agent process. Unlike the infrastructure vars above,
# these reach the agent via the explicit `environment:` passthrough in
# docker-compose.yml (e.g. the DISCLAUDE_ALLOW_BUILTIN_CRON line), so setting
# them here takes effect after `docker compose up -d`.

# Re-enable Claude Code's built-in (session-only) cron/loop tools for chat
# agents, which are disallowed by default (Issue #4181). Useful for ad-hoc use
# of the built-in /loop dynamic mode; leave commented to keep the persistent
# `schedule` skill as the only scheduling mechanism.
# DISCLAUDE_ALLOW_BUILTIN_CRON=1

# =============================================================================
# GPU Support (optional) — Issue #4285
# =============================================================================
# Opt-in GPU runtime for the `primary` service (the compute/agent service that
# runs Python/ML workloads). All vars default to CPU-only-safe values, so
# leaving this section commented keeps `docker compose up -d` unchanged on
# hosts WITHOUT nvidia-container-toolkit.
#
# Prerequisites (see docs/gpu-setup.md):
#   1. nvidia-container-toolkit installed on the host.
#   2. `docker info` lists "nvidia" under "Runtimes".
#   3. Docker Compose v2 (Go) — the `runtime:` service key is required.
#
# Approach: Alpine base image is kept; GPU is exposed purely via
# `runtime: nvidia` (approach b in #4285). CUDA/cuDNN come bundled with the
# torch/conda wheels the agent installs, so no Dockerfile change is needed.
#
# Enable GPU, e.g.:
#   DOCKER_RUNTIME=nvidia SHM_SIZE=4G WORKER_MEMORY=40G \
#     NVIDIA_VISIBLE_DEVICES=all docker compose up -d

# Docker runtime for the primary container. "default" = standard runc (CPU-only,
# no-op). Set to "nvidia" on a GPU host to mount the host GPUs.
# Default: default
# DOCKER_RUNTIME=nvidia

# /dev/shm size. GPU ML workloads (PyTorch DataLoader with num_workers>0,
# torch multiprocessing) crash with Bus error on the default 64MB /dev/shm.
# Set to 4G (or larger) when enabling GPU.
# Default: 64m (the container default — unchanged from CPU-only)
# SHM_SIZE=4G

# Memory limit for the primary container. GPU ML workloads (large numpy/torch
# matrices, model inference) need far more than the 16G CPU default.
# Default: 16G (unchanged from CPU-only)
# WORKER_MEMORY=40G

# Which GPUs to expose. Maps to the nvidia-container-runtime env var. "all"
# exposes every GPU; "0" / "0,1" / "GPU-uuid" for a subset. Only effective when
# DOCKER_RUNTIME=nvidia. (This is read by the nvidia runtime, NOT interpolated
# by compose, so it must be exported in your shell, not just set here — see
# docs/gpu-setup.md.)
# NVIDIA_VISIBLE_DEVICES=all
