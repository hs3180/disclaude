# =============================================================================
# Disclaude Worker Node Dockerfile
# =============================================================================
# Multi-stage build for Worker Node - handles ChatAgent task execution.
# Includes Python runtime for data analysis tasks.
#
# Build:
#   docker build -f Dockerfile.worker -t disclaude:worker .
#
# Run:
#   docker run -v $(pwd)/disclaude.config.yaml:/app/disclaude.config.yaml \
#     -e COMM_URL=ws://primary:3001 \
#     disclaude:worker
#
# For production deployment, use docker-compose.yml.
# =============================================================================

# -----------------------------------------------------------------------------
# Build arguments for configurable source mirrors (Issue #2283)
# Defaults use official sources; override via docker-source.env for mirrors.
# -----------------------------------------------------------------------------
ARG DOCKER_IMAGE_PREFIX=
ARG APK_MIRROR=dl-cdn.alpinelinux.org
ARG NPM_REGISTRY=https://registry.npmjs.org
ARG PIP_INDEX_URL=https://pypi.org/simple

# -----------------------------------------------------------------------------
# Stage 1: Builder
# -----------------------------------------------------------------------------
FROM ${DOCKER_IMAGE_PREFIX}library/node:22-alpine AS builder

# Re-declare build args for use in this stage
ARG APK_MIRROR
ARG NPM_REGISTRY

WORKDIR /app

# Configure apk mirror (default: official Alpine CDN)
RUN sed -i "s|dl-cdn.alpinelinux.org|${APK_MIRROR}|g" /etc/apk/repositories

# Install build dependencies
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package.json package-lock.json ./
COPY packages ./packages

# Configure npm registry and install all dependencies (including devDependencies for building)
RUN npm config set registry ${NPM_REGISTRY} && \
    npm install

# Copy source code (explicitly list needed dirs to avoid traversing excluded directories like workspace)
COPY skills ./skills
COPY ecosystem.worker.config.json ./ecosystem.worker.config.json

# Build the project
RUN npm run build

# Prune devDependencies for production
RUN npm prune --production && \
    npm cache clean --force

# -----------------------------------------------------------------------------
# Stage 2: Production Image (Node.js 22 + Python for data analysis)
# Uses node:22-alpine as base to guarantee globalThis.WebSocket support.
# -----------------------------------------------------------------------------
FROM ${DOCKER_IMAGE_PREFIX}library/node:22-alpine AS production

# Re-declare build args for use in this stage
ARG APK_MIRROR
ARG NPM_REGISTRY
ARG PIP_INDEX_URL

WORKDIR /app

# Configure apk mirror (default: official Alpine CDN)
RUN sed -i "s|dl-cdn.alpinelinux.org|${APK_MIRROR}|g" /etc/apk/repositories

# Install Python and runtime dependencies via apk
# Note: Alpine uses musl libc instead of glibc
RUN apk add --no-cache \
    python3 \
    py3-pip \
    curl \
    ca-certificates \
    procps \
    github-cli \
    # Build dependencies for Python packages with native extensions
    build-base \
    libffi-dev \
    openssl-dev \
    python3-dev \
    # Dependencies for matplotlib
    freetype-dev \
    libpng-dev \
    # Dependencies for scipy/numpy
    openblas-dev \
    gfortran

# Install Python data analysis libraries
# Use --break-system-packages for Alpine's externally managed environment
RUN pip install --no-cache-dir --break-system-packages --upgrade pip && \
    pip install --no-cache-dir --break-system-packages \
    --index-url ${PIP_INDEX_URL} \
    pandas \
    numpy \
    scipy \
    matplotlib \
    seaborn \
    scikit-learn \
    plotly \
    openpyxl \
    xlrd \
    requests \
    pydantic

# Install PM2 globally for process management
RUN npm config set registry ${NPM_REGISTRY} && \
    npm install -g pm2@latest

# Create non-root user for running the application (Alpine style)
RUN addgroup -g 1001 disclaude && \
    adduser -D -u 1001 -G disclaude -h /app -s /sbin/nologin disclaude

# Create directories for runtime with proper permissions
RUN mkdir -p /app/workspace /app/logs /app/.claude /app/.claude/backups /app/.claude/debug /app/.pm2 && \
    echo '{}' > /app/.claude.json && \
    chown -R disclaude:disclaude /app

# Copy built artifacts and production dependencies from builder
COPY --from=builder --chown=disclaude:disclaude /app/packages ./packages
COPY --from=builder --chown=disclaude:disclaude /app/node_modules ./node_modules
COPY --from=builder --chown=disclaude:disclaude /app/package.json ./
COPY --from=builder --chown=disclaude:disclaude /app/package-lock.json ./
COPY --from=builder --chown=disclaude:disclaude /app/ecosystem.worker.config.json ./
COPY --from=builder --chown=disclaude:disclaude /app/skills ./skills

# Set environment variables
ENV NODE_ENV=production
ENV PYTHONUNBUFFERED=1
ENV DISCLAUDE_MODE=worker

# Health check - check if PM2 process is running
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD pm2 pid disclaude-worker > /dev/null 2>&1 || exit 1

# Switch to non-root user
USER disclaude

# Default command: run Worker Node with PM2
CMD ["pm2-runtime", "start", "ecosystem.worker.config.json"]
