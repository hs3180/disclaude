# =============================================================================
# Disclaude MCP Server Dockerfile
# =============================================================================
# Multi-stage build for MCP Server - provides MCP tools and resources.
#
# This image is optimized for the MCP Server process with:
# - Minimal base image (node:20-alpine)
# - Only runtime dependencies
# - Non-root user for security
#
# Build:
#   docker build -f Dockerfile.mcp -t disclaude:mcp .
#
# Run:
#   docker run -v $(pwd)/disclaude.config.yaml:/app/disclaude.config.yaml disclaude:mcp
#
# Architecture Note:
#   Currently uses full src/ codebase. Future versions will use only
#   packages/core and packages/mcp-server after code migration.
#
# =============================================================================

# -----------------------------------------------------------------------------
# Stage 1: Dependencies
# -----------------------------------------------------------------------------
FROM node:20-alpine AS deps
WORKDIR /app

# Install build dependencies for native modules
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package.json package-lock.json ./

# Configure npm mirror and install dependencies
RUN npm config set registry https://registry.npmmirror.com && \
    npm ci --omit=dev && \
    npm cache clean --force

# -----------------------------------------------------------------------------
# Stage 2: Builder
# -----------------------------------------------------------------------------
FROM node:20-alpine AS builder
WORKDIR /app

# Install build dependencies
RUN apk add --no-cache python3 make g++

# Copy package files
COPY package.json package-lock.json ./

# Configure npm mirror and install all dependencies (including devDependencies for building)
RUN npm config set registry https://registry.npmmirror.com && \
    npm ci

# Copy source code
COPY . .

# Build the project
RUN npm run build

# -----------------------------------------------------------------------------
# Stage 3: Production Image
# -----------------------------------------------------------------------------
FROM node:20-alpine AS production
WORKDIR /app

# Install runtime dependencies
RUN apk add --no-cache \
    # Curl for health checks
    curl \
    # CA certificates for HTTPS connections
    ca-certificates

# Create non-root user for running the application
RUN addgroup -g 1001 disclaude && \
    adduser -D -u 1001 -G disclaude -h /app -s /sbin/nologin disclaude

# Create directories for runtime with proper permissions
RUN mkdir -p /app/workspace /app/logs /app/.claude /app/.pm2 && \
    chown -R disclaude:disclaude /app

# Copy built artifacts from builder and production dependencies from deps
COPY --from=builder --chown=disclaude:disclaude /app/dist ./dist
COPY --from=deps --chown=disclaude:disclaude /app/node_modules ./node_modules
COPY --from=builder --chown=disclaude:disclaude /app/package.json ./

# Copy skills directory (MCP tools may need skills)
COPY --from=builder --chown=disclaude:disclaude /app/skills ./skills

# Set environment variables
ENV NODE_ENV=production
ENV DISCLAUDE_MODE=mcp

# Health check - check if node process is running
HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
    CMD pgrep -f "node.*mcp" > /dev/null 2>&1 || exit 1

# Switch to non-root user
USER disclaude

# Default command: run MCP Server
# Note: MCP server typically runs via stdio, adjust as needed
CMD ["node", "dist/mcp/index.js"]
