{
  "name": "disclaude",
  "version": "0.4.0",
  "description": "Multi-platform agent bot supporting Feishu/Lark and CLI",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "disclaude": "./packages/primary-node/dist/cli.js",
    "disclaude-primary": "./packages/primary-node/dist/cli.js",
    "disclaude-mcp": "./packages/mcp-server/dist/cli.js"
  },
  "scripts": {
    "build": "npm run build -ws --if-present",
    "build:packages": "npm run build -ws --if-present",
    "build:core": "npm run build --workspace=@disclaude/core",
    "build:primary": "npm run build --workspace=@disclaude/primary-node",
    "build:mcp": "npm run build --workspace=@disclaude/mcp-server",
    "type-check": "npm run build && tsc --noEmit",
    "lint": "eslint packages/*/src --max-warnings=0",
    "lint:fix": "eslint packages/*/src --fix",
    "format": "prettier --write \"packages/*/src/**/*.ts\"",
    "format:check": "prettier --check \"packages/*/src/**/*.ts\"",
    "test": "npm run build && vitest --run",
    "test:watch": "vitest",
    "test:coverage": "npm run build && vitest --run --coverage",
    "test:integration": "./tests/integration/run-all-tests.sh",
    "test:integration:rest": "./tests/integration/rest-channel-test.sh",
    "test:integration:use-case-1": "./tests/integration/use-case-1-basic-reply.sh",
    "test:integration:use-case-2": "./tests/integration/use-case-2-task-execution.sh",
    "test:integration:multi-turn": "./tests/integration/use-case-3-multi-turn.sh",
    "test:integration:mcp": "./tests/integration/mcp-tools-test.sh",
    "test:integration:multimodal": "./tests/integration/multimodal-test.sh",
    "test:integration:fast": "./tests/integration/run-all-tests.sh --tag fast",
    "test:integration:ai": "./tests/integration/run-all-tests.sh --tag ai",
    "test:feishu": "./tests/integration/feishu-ipc-test.sh",
    "test:rfc3329": "./tests/integration/rfc3329-test.sh",
    "launchd:generate": "node scripts/launchd.mjs generate",
    "launchd:install": "node scripts/launchd.mjs install",
    "launchd:uninstall": "node scripts/launchd.mjs uninstall",
    "launchd:start": "node scripts/launchd.mjs start",
    "launchd:stop": "node scripts/launchd.mjs stop",
    "launchd:restart": "node scripts/launchd.mjs restart",
    "launchd:logs": "node scripts/launchd.mjs logs",
    "launchd:status": "node scripts/launchd.mjs status",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/qrcode": "1.5.6",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.17.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "nock": "14.0.11",
    "prettier": "^3.4.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^3.0.0",
    "vitest-tsconfig-paths": "^3.4.1"
  },
  "lint-staged": {
    "packages/*/src/**/*.ts": [
      "eslint --max-warnings=0 --fix"
    ]
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hs3180/disclaude.git"
  },
  "bugs": {
    "url": "https://github.com/hs3180/disclaude/issues"
  },
  "homepage": "https://github.com/hs3180/disclaude#readme",
  "dependencies": {
    "qrcode": "1.5.4"
  }
}
