# =============================================================================
# Disclaude Docker Build Source Configuration
# =============================================================================
#
# This file configures package source mirrors for Docker builds.
# Copy this file to `docker-source.env` and uncomment/modify the lines
# for the mirrors you need.
#
# When `docker-source.env` does not exist, all official sources are used.
#
# USAGE:
#   cp docker-source.env.example docker-source.env
#   # Uncomment and modify the mirror URLs you need
#   docker compose build
#
# =============================================================================

# Alpine apk mirror
# Default: dl-cdn.alpinelinux.org
# China mirrors: mirrors.ustc.edu.cn, mirrors.aliyun.com, mirrors.tuna.tsinghua.edu.cn
# APK_MIRROR=mirrors.ustc.edu.cn

# npm registry
# Default: https://registry.npmjs.org
# China mirrors: https://registry.npmmirror.com
# NPM_REGISTRY=https://registry.npmmirror.com

# pip index URL
# Default: https://pypi.org/simple
# China mirrors: https://pypi.tuna.tsinghua.edu.cn/simple, https://mirrors.aliyun.com/pypi/simple
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple

# Docker base image prefix
# Default: (empty = docker.io)
# China mirrors: docker.m.daocloud.io
# DOCKER_IMAGE_PREFIX=docker.m.daocloud.io

# Playwright CDP endpoint URL
# Used by the Playwright MCP server to connect to a remote browser instance.
# When using the optional playwright container (docker compose --profile playwright up),
# set this to the CDP WebSocket URL.
# Default: (empty = Playwright MCP launches its own browser)
# PLAYWRIGHT_CDP_URL=ws://localhost:3000

# Playwright CDP port (host port mapping for the playwright container)
# Default: 3000
# PLAYWRIGHT_CDP_PORT=3000
