# Environment variables
.env
**/.runtime-env

# Configuration file with secrets
disclaude.config.yaml
disclaude.config.test.yaml

# Docker source mirror configuration (user-specific)
docker-source.env

# Environment initialization (user-specific)
.disclauderc

# Node.js
node_modules/
dist/
*.tsbuildinfo

# Test coverage
coverage/

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Logs (keep directory, ignore contents)
logs/*
!logs/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/

# Disclaude project state (Issue #3335)
.disclaude/

# Playwright MCP
.playwright-mcp/
.mcp.json

# Task records
tasks/

# Workspace directory (runtime data — auto-created at startup, ignore contents)
# Issue #4254: workspace dir is created by ensureWorkspaceDir() (and mkdir -p
# in Dockerfile.primary), so no tracked .gitkeep placeholder is needed.
workspace/*

# Integration test environment (contains secrets)
tests/integration/test-env.yaml
tests/integration/workspace/
disclaude-test-server.log

# Temporary analysis reports generated by AI agents
*_ANALYSIS.md
*_REPORT.md
*_SUMMARY.md

# Test data
data/
